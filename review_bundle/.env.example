# Stonk News Configuration Example
# Copy this file to config/secrets.env and fill in your API keys

# Primary Data Source (Required)
ALPHA_VANTAGE_KEY=your_alpha_vantage_key_here

# Email Configuration (Required)
GMAIL_USER=your_email@gmail.com
GMAIL_PASSWORD=your_app_password_here

# Feature Flags (Optional - default: false)
ENABLE_MULTISOURCE_PRICES=false
ENABLE_PAID_SOURCES=false
ENABLE_ALPHA_VANTAGE_BATCHING=false
ENABLE_NEWSAPI_INGESTION=false
ENABLE_FINBERT_PIPELINE=false
ENABLE_FINBERT_BACKTEST=false
ENABLE_PORTFOLIO_ANALYTICS=false
ENABLE_90_DAY_SENTIMENT=false
ENABLE_NEWS_CORROBORATION=false
ENABLE_YF_PRICES=false
ENABLE_YF_PROFILES=false
ENABLE_YF_BACKOFF_DEBUG=false
ENABLE_DEBUG_MODE=false
ENABLE_SMART_ALERTS=false
ENABLE_API_ENDPOINTS=false
ENABLE_SYMBOL_INTAKE=false
ENABLE_EARNINGS_READS=false
ENABLE_RECOS=false
ENABLE_ASYNC_IO=false

# Premium Data Sources (Optional - only needed if ENABLE_PAID_SOURCES=true)
FINNHUB_TOKEN=your_finnhub_token_here
POLYGON_KEY=your_polygon_api_key_here
EODHD_KEY=your_eodhd_api_key_here

# News API (F03 - Optional - only needed if ENABLE_NEWSAPI_INGESTION=true)
NEWSAPI_KEY=your_newsapi_key_here

# FinBERT Configuration (F04 - Optional)
FINBERT_LAMBDA=0.2
FINBERT_BARRIER_DAYS=29

# Data Source Configuration (Optional)
NEWS_LOOKBACK_DAYS=30
INTAKE_MAX_QUEUE_SIZE=100
INTAKE_JOB_TIMEOUT=300
NEWS_MIN_SOURCES=2
NEWS_CONFIDENCE_THRESHOLD=0.7

# YFinance Configuration (Optional - for free tier rate limiting)
YF_CACHE_TTL_HOURS=24
YF_MAX_RETRIES=4
YF_BACKOFF_BASE_SECONDS=2
YF_THREADS=1

# API Configuration (Optional)
API_HOST=localhost
API_PORT=8000
API_DEBUG=false
API_KEY=your_secure_api_key_here

# F09 Async I/O Configuration (Optional)
MAX_CONCURRENCY=5
BACKOFF_MAX=60
CIRCUIT_FAILURE_THRESHOLD=5
CIRCUIT_RECOVERY_TIMEOUT=60
CACHE_TTL=86400
REQUEST_TIMEOUT=30